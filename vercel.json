{
  "version": 2,
  "buildCommand": "echo 'Build skipped'",
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "zeroConfig": true,
        "includeFiles": [
          "server/**/*.js",
          "server/**/*.json",
          "server/public/**/*"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}
